# Copy to `.env.hetzner` before deploying to a Hetzner VM.
#
# This base file matches the current public production posture:
# - direct Caddy -> FastAPI proxying
# - no oauth2-proxy in front of the app
# - app auth mode left `off`
#
# If you later enable SSO, keep this file and deploy with:
#   docker compose -f deploy/hetzner/docker-compose.yml \
#     -f deploy/hetzner/docker-compose.oidc.yml \
#     --env-file deploy/hetzner/.env.hetzner up --build -d

# Domain / TLS
DOMAIN=munirevenue.com

# Database
POSTGRES_USER=munirev
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=munirev
DATABASE_URL=postgresql://munirev:replace-with-a-long-random-password@postgres:5432/munirev

# App security posture (current live-compatible mode)
MUNIREV_API_AUTH_MODE=off
MUNIREV_PROXY_SUBJECT_HEADERS=X-Auth-Request-Email,X-Auth-Request-User
MUNIREV_PROXY_ROLE_HEADERS=X-Auth-Request-Groups
MUNIREV_PROXY_DEFAULT_ROLES=viewer
MUNIREV_AUTH_EXEMPT_PATHS=/api/health
MUNIREV_RATE_LIMIT_ENABLED=true
MUNIREV_RATE_LIMIT_REQUESTS=120
MUNIREV_RATE_LIMIT_WINDOW_SECONDS=60
MUNIREV_RATE_LIMIT_EXEMPT_PATHS=/api/health
MUNIREV_TRUST_X_FORWARDED_FOR=true
MUNIREV_ALLOWED_HOSTS=munirevenue.com,www.munirevenue.com
MUNIREV_FORCE_HTTPS=false
MUNIREV_OPENAPI_ENABLED=true
MUNIREV_CORS_ORIGINS=https://munirevenue.com,https://www.munirevenue.com
MUNIREV_CSRF_TRUSTED_ORIGINS=https://munirevenue.com,https://www.munirevenue.com

# Optional machine-to-machine JWT validation
MUNIREV_JWT_SECRET=
MUNIREV_JWT_ISSUER=
MUNIREV_JWT_AUDIENCE=

# Optional oauth2-proxy / OIDC overlay
# To enable:
# - set MUNIREV_API_AUTH_MODE=proxy
# - set MUNIREV_FORCE_HTTPS=true
# - set MUNIREV_OPENAPI_ENABLED=false
# - deploy with `-f deploy/hetzner/docker-compose.oidc.yml`
OAUTH2_PROXY_OIDC_ISSUER_URL=https://auth.example.com/application/o/munirev/
OAUTH2_PROXY_CLIENT_ID=replace-with-client-id
OAUTH2_PROXY_CLIENT_SECRET=replace-with-client-secret
# 32-byte base64-encoded secret generated with:
#   openssl rand -base64 32
OAUTH2_PROXY_COOKIE_SECRET=replace-with-cookie-secret
OAUTH2_PROXY_REDIRECT_URL=https://munirevenue.com/oauth2/callback
