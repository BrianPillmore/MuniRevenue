# =============================================================================
# MuniRev -- Environment Variables
# =============================================================================
# Copy this file to .env and replace the placeholder values before deploying.
#
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# =============================================================================

# -- PostgreSQL ---------------------------------------------------------------
POSTGRES_USER=munirev
POSTGRES_PASSWORD=changeme
POSTGRES_DB=munirev

# -- Application database connection -----------------------------------------
DATABASE_URL=postgresql://munirev:changeme@postgres:5432/munirev

# -- Caddy / TLS -------------------------------------------------------------
# Set to your real domain (e.g. munirev.example.com) for automatic HTTPS.
# Leave as "localhost" for local development (plain HTTP on port 80).
DOMAIN=localhost

# -- API security ------------------------------------------------------------
# Authentication modes:
#   off   = no API auth (local development)
#   token = require X-API-Key or Authorization: Bearer <token|jwt>
#   proxy = require a trusted upstream auth header such as X-Auth-Request-Email
MUNIREV_API_AUTH_MODE=off

# Comma-separated static secrets for token mode.
MUNIREV_API_KEYS=
MUNIREV_BEARER_TOKENS=

# Default roles/scopes applied to static API keys or bearer tokens.
MUNIREV_TOKEN_DEFAULT_ROLES=viewer
MUNIREV_TOKEN_DEFAULT_SCOPES=

# Optional JWT validation for Bearer tokens (HS256 only).
MUNIREV_JWT_SECRET=
MUNIREV_JWT_ISSUER=
MUNIREV_JWT_AUDIENCE=
MUNIREV_JWT_CLOCK_SKEW_SECONDS=30

# Comma-separated header names checked in proxy mode.
# `MUNIREV_PROXY_AUTH_HEADERS` is kept for backward compatibility.
MUNIREV_PROXY_AUTH_HEADERS=X-Authenticated-User,X-Forwarded-User
MUNIREV_PROXY_SUBJECT_HEADERS=X-Auth-Request-Email,X-Auth-Request-User
MUNIREV_PROXY_ROLE_HEADERS=X-Auth-Request-Groups
MUNIREV_PROXY_SCOPE_HEADERS=X-Authenticated-Scopes,X-Forwarded-Scopes
MUNIREV_PROXY_DEFAULT_ROLES=viewer
MUNIREV_PROXY_DEFAULT_SCOPES=

# Paths that stay publicly accessible even when auth is enabled.
MUNIREV_AUTH_EXEMPT_PATHS=/api/health

# -- Rate limiting -----------------------------------------------------------
MUNIREV_RATE_LIMIT_ENABLED=true
MUNIREV_RATE_LIMIT_REQUESTS=120
MUNIREV_RATE_LIMIT_WINDOW_SECONDS=60
MUNIREV_RATE_LIMIT_EXEMPT_PATHS=/api/health

# Only enable this behind a trusted reverse proxy that sets X-Forwarded-For.
MUNIREV_TRUST_X_FORWARDED_FOR=false

# -- Host / transport hardening ---------------------------------------------
# Comma-separated list used by TrustedHostMiddleware.
MUNIREV_ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# Force HTTPS redirects in production once TLS is terminated correctly.
MUNIREV_FORCE_HTTPS=false

# Keep interactive API docs off in production unless explicitly needed.
MUNIREV_OPENAPI_ENABLED=true

# -- CORS -------------------------------------------------------------------
# Comma-separated list of allowed browser origins for API requests.
MUNIREV_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Trusted origins for unsafe browser requests when running in proxy auth mode.
MUNIREV_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
