# =============================================================================
# MuniRevenue -- Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# =============================================================================

# -- PostgreSQL ---------------------------------------------------------------
POSTGRES_USER=munirev
POSTGRES_PASSWORD=
POSTGRES_DB=munirev

# -- Application database connection -----------------------------------------
DATABASE_URL=postgresql://munirev:YOUR_PASSWORD@postgres:5432/munirev

# -- Caddy / TLS -------------------------------------------------------------
DOMAIN=localhost

# -- API security ------------------------------------------------------------
MUNIREV_API_AUTH_MODE=off
MUNIREV_API_KEYS=
MUNIREV_BEARER_TOKENS=
MUNIREV_TOKEN_DEFAULT_ROLES=viewer
MUNIREV_TOKEN_DEFAULT_SCOPES=
MUNIREV_JWT_SECRET=
MUNIREV_JWT_ISSUER=
MUNIREV_JWT_AUDIENCE=
MUNIREV_JWT_CLOCK_SKEW_SECONDS=30

# -- Proxy auth ---------------------------------------------------------------
MUNIREV_PROXY_AUTH_HEADERS=X-Authenticated-User,X-Forwarded-User
MUNIREV_PROXY_SUBJECT_HEADERS=X-Auth-Request-Email,X-Auth-Request-User
MUNIREV_PROXY_ROLE_HEADERS=X-Auth-Request-Groups
MUNIREV_PROXY_SCOPE_HEADERS=X-Authenticated-Scopes,X-Forwarded-Scopes
MUNIREV_PROXY_DEFAULT_ROLES=viewer
MUNIREV_PROXY_DEFAULT_SCOPES=
MUNIREV_AUTH_EXEMPT_PATHS=/api/health

# -- Economic indicators (FRED API) ------------------------------------------
FRED_API_KEY=
BLS_API_KEY=
CENSUS_API_KEY=

# -- Rate limiting -----------------------------------------------------------
MUNIREV_RATE_LIMIT_ENABLED=false
MUNIREV_RATE_LIMIT_REQUESTS=120
MUNIREV_RATE_LIMIT_WINDOW_SECONDS=60
MUNIREV_RATE_LIMIT_EXEMPT_PATHS=/api/health
MUNIREV_TRUST_X_FORWARDED_FOR=false

# -- Host / transport hardening ---------------------------------------------
MUNIREV_ALLOWED_HOSTS=localhost,127.0.0.1
MUNIREV_FORCE_HTTPS=false
MUNIREV_OPENAPI_ENABLED=true

# -- CORS -------------------------------------------------------------------
MUNIREV_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
MUNIREV_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# -- Browser auth / magic links ---------------------------------------------
MUNIREV_AUTH_MAGIC_LINK_ENABLED=false
MUNIREV_AUTH_MAGIC_LINK_BASE_URL=http://127.0.0.1:8000
MUNIREV_AUTH_MAGIC_LINK_TTL_MINUTES=15
MUNIREV_AUTH_MAGIC_LINK_RATE_LIMIT_WINDOW_SECONDS=900
MUNIREV_AUTH_MAGIC_LINK_RATE_LIMIT_PER_EMAIL=5
MUNIREV_AUTH_MAGIC_LINK_RATE_LIMIT_PER_IP=20
MUNIREV_AUTH_LOGIN_SUCCESS_REDIRECT=/account
MUNIREV_AUTH_COOKIE_NAME=munirev_session
MUNIREV_AUTH_COOKIE_SECURE=false
MUNIREV_AUTH_COOKIE_SAMESITE=lax
MUNIREV_AUTH_SESSION_DAYS=30
MUNIREV_AUTH_SESSION_SECRET=
MUNIREV_AUTH_DEBUG_RETURN_MAGIC_LINK=false
MUNIREV_EMAIL_MODE=log
MUNIREV_EMAIL_FROM=noreply@munirevenue.com
MUNIREV_AUTH_MAGIC_LINK_SUBJECT=Your MuniRevenue sign-in link
MUNIREV_AUTH_VERIFY_EMAIL_SUBJECT=Verify your MuniRevenue email
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
